<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="warehouse_robot">

  <xacro:property name="base_width" value="0.335"/>
  <xacro:property name="base_length" value="0.335"/>
  <xacro:property name="base_height" value="0.07"/>

  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_width" value="0.04"/>
  <xacro:property name="wheel_ygap" value="-0.02"/>
  <xacro:property name="caster_xoff" value="0.14"/>

  <!-- ================= Inertial macros ================= -->
  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${(m/12) * (h*h + d*d)}"
        ixy="0.0"
        ixz="0.0"
        iyy="${(m/12) * (w*w + d*d)}"
        iyz="0.0"
        izz="${(m/12) * (w*w + h*h)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${(m/12) * (3*r*r + h*h)}"
        ixy="0.0"
        ixz="0.0"
        iyy="${(m/12) * (3*r*r + h*h)}"
        iyz="0.0"
        izz="${(m/2) * (r*r)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${(2/5) * m * (r*r)}"
        ixy="0.0"
        ixz="0.0"
        iyy="${(2/5) * m * (r*r)}"
        iyz="0.0"
        izz="${(2/5) * m * (r*r)}"/>
    </inertial>
  </xacro:macro>

  <!-- ================= Base ================= -->
  <link name="base_footprint"/>

  <link name="body_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
     
    </visual>

    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>

    <xacro:box_inertia m="2" w="${base_width}" h="${base_height}" d="${base_length}"/>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="body_link"/>
    <origin xyz="0 0 ${2*wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ================= Wheel macro ================= -->
  <xacro:macro name="wheel" params="prefix y_reflect">
    <link name="${prefix}_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        
      </collision>

      <xacro:cylinder_inertia m="0.5" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${prefix}_joint" type="continuous">
      <parent link="body_link"/>
      <child link="${prefix}_link"/>
      <origin xyz="0 ${y_reflect*(base_width/2 + wheel_ygap)} ${-wheel_radius}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit  velocity="7.0" effort="50.0"/>
      <dynamics damping="0.2"/>
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="drivewhl_l" y_reflect="1"/>
  <xacro:wheel prefix="drivewhl_r" y_reflect="-1"/>

  <!-- ================= Caster macro ================= -->
  <xacro:macro name="caster" params="prefix x_offset">
    <link name="${prefix}_caster">
      <visual>
        <geometry>
          <sphere radius="${wheel_radius}"/>
        </geometry>
        
      </visual>

      <collision>
        <geometry>
          <sphere radius="${wheel_radius}"/>
        </geometry>
       
      </collision>

      <xacro:sphere_inertia m="0.1" r="${wheel_radius}"/>
    </link>

    <joint name="${prefix}_caster_joint" type="fixed">
      <parent link="body_link"/>
      <child link="${prefix}_caster"/>
      <origin xyz="${x_offset} 0 ${-wheel_radius}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:caster prefix="front" x_offset="${caster_xoff}"/>
  <xacro:caster prefix="back" x_offset="${-caster_xoff}"/>
  

  <!-- ================= Vertical extrusion ================= -->
  <link name="vertical_extrusion">
    <visual>
      <origin xyz="0 0 0.825" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 1.65"/>
      </geometry>
      
    </visual> 

    <collision>
      <origin xyz="0 0 0.825" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 1.65"/>
      </geometry>
    </collision>

    <xacro:box_inertia m="1" w="0.01" h="1.65" d="0.01"/>
  </link>

  <joint name="vertical_extrusion_joint" type="fixed">
    <parent link="body_link"/>
    <child link="vertical_extrusion"/>
    <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ================= Camera ================= -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
     
    </visual>

    <collision>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
    </collision>

    <xacro:box_inertia m="0.05" w="0.02" h="0.02" d="0.02"/>

    
  </link>

  <joint name="camera_joint" type="prismatic">
    <parent link="vertical_extrusion"/>
    <child link="camera_link"/>
    <origin xyz="0 0 0.02" rpy="0 0 -1.57"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="1.5" velocity="5.0" effort="100.0"/>
  </joint>

 
  <!-- ================= IMU ================= -->
  <joint name="imu_joint" type="fixed">
    <parent link="body_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
    </collision>

    <xacro:box_inertia m="0.01" w="0.1" h="0.1" d="0.1"/>

  </link>
  <!-- ================= Lidar ================= -->
  <joint name="lidar_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 ${base_height/2 + wheel_radius*2+0.005}" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.015"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.02" length="0.015"/>
      </geometry>
    </collision>

    <xacro:cylinder_inertia m="0.025" r="0.02" h="0.015"/>
  </link>

  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
        <always_on>true</always_on>
        <visualize>true</visualize>
        <update_rate>30</update_rate>
        <topic>scan</topic>
        <gz_frame_id>lidar_link</gz_frame_id>
        <ray>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1.000000</resolution>
              <min_angle>0.000000</min_angle>
              <max_angle>6.28318531</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.020000</min>
            <max>20.0</max>
            <resolution>0.015000</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.001</stddev>
          </noise>
        </ray>
      </sensor>
  </gazebo>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <visualize>true</visualize>
        <topic>imu</topic>
        <gz_frame_id>imu_link</gz_frame_id>
      </sensor>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
        <always_on>true</always_on>
        <update_rate>15</update_rate>
        <visualize>true</visualize>
        <topic>camera/image_raw</topic>
        <gz_frame_id>camera_link</gz_frame_id>
        <camera>
          <horizontal_fov>1.92</horizontal_fov>
          <image>
            <width>1920</width>
            <height>1080</height>
          </image>
          <clip>
            <near>0.01</near>
            <far>100.0</far>
          </clip>
        </camera>
      </sensor>
  </gazebo>

  <!-- ================= Diff drive plugin ================= 
  <gazebo>
    <plugin filename="libgz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>drivewhl_l_joint</left_joint>
      <right_joint>drivewhl_r_joint</right_joint>
      <wheel_separation>${2*(base_width/2 + wheel_ygap)}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <odom_publish_frequency>50.0</odom_publish_frequency>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>

      
    </plugin>
  </gazebo> -->

  <!-- ================= Joint state publisher ================= 
  <gazebo>
    <plugin filename="libgz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>
  </gazebo> -->

  
   <!-- ================= ros2_control ================= -->
  <ros2_control name="warehouse_robot" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="camera_joint">
      <command_interface name="position">
      <param name="min">0.0</param>
        <param name="max">1.5</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.1</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="drivewhl_l_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>

    <joint name="drivewhl_r_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
  </ros2_control>

  <!-- ================= Gazebo plugin ================= -->
  <gazebo>
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find warehouse_robot_bringup)/config/ros2_controller.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo reference="vertical_extrusion">
    <visual>
      <material>
        <ambient>0 0.8 0 1</ambient>
        <diffuse>0 0.8 0 1</diffuse>
        <specular>0 0.8 0 1</specular>
      </material>
    </visual>
  </gazebo>

  <gazebo reference="camera_link">
    <visual>
      <material>
        <ambient>0 0 0.8 1</ambient>
        <diffuse>0 0 0.8 1</diffuse>
        <specular>0 0 0.8 1</specular>
      </material>
    </visual>
  </gazebo>

</robot>